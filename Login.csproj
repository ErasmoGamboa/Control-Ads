<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <AssemblyName>Control Ads</AssemblyName>
    <FileVersion>1.0.0.0</FileVersion>
    <Company>Compurobotik C.A.</Company>
    <Product>Control Ads</Product>
    <ApplicationIcon>Control Ads.ico</ApplicationIcon>
    <Copyright>Copyright © 2026 Compurobotik C.A.</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Control Ads.ico">
       <LogicalName>Red Monitor.ico</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Drawing" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
  </ItemGroup>
</Project>